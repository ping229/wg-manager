# WireGuard 管理系统配置文件

# ============ Portal 配置 ============
# JWT 密钥 (Portal 独立，无需与 Admin 相同)
SECRET_KEY=change-this-secret-key-in-production

# 数据加密密钥 (32字节，用于加密存储的 API Key)
ENCRYPTION_KEY=change-this-encryption-key-32bytes!!

# Portal 名称 (发送给 Admin 显示)
PORTAL_NAME=WireGuard Portal

# Portal API 密钥 (供 Admin 回调使用，自动生成或手动设置)
PORTAL_API_KEY=

# Portal 服务配置
PORTAL_HOST=0.0.0.0
PORTAL_PORT=8080

# Portal 外部访问地址 (用于 Admin 回调，可选)
# PORTAL_URL=http://your-portal-host:8080

# 数据库路径
DATABASE_URL=sqlite:////opt/wg-manager/data/portal.db

# ============ Admin 配置 ============
# JWT 密钥 (Admin 独立)
# SECRET_KEY=change-this-secret-key-in-production

# 数据加密密钥 (32字节，用于加密存储的敏感数据)
# ENCRYPTION_KEY=change-this-encryption-key-32bytes!!

# 超级管理员初始密码
SUPER_ADMIN_PASSWORD=admin123

# Admin 服务配置
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8081

# Admin 外部访问地址 (用于通知 Portal)
# ADMIN_URL=http://your-admin-host:8081

# ============ Agent 配置 ============
AGENT_HOST=127.0.0.1
AGENT_PORT=8082
DEFAULT_AGENT_URL=http://127.0.0.1:8082
AGENT_API_KEY=

# ============ 部署说明 ============
# 1. Portal 部署后，访问首页配置 Admin 连接信息
# 2. 点击"申请接入"发送申请到 Admin
# 3. Admin 在"Portal接入管理"中审核申请
# 4. 审核通过后 Portal 自动变为可用状态
