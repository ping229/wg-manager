# 环境变量配置

# JWT密钥 (Portal 和 Admin 必须使用相同密钥以便 JWT 验证)
SECRET_KEY=change-this-secret-key-in-production

# 数据加密密钥 (32字节，仅 Admin 使用)
ENCRYPTION_KEY=change-this-encryption-key-32bytes!!

# 超级管理员初始密码 (仅 Admin 使用)
SUPER_ADMIN_PASSWORD=admin123

# ============ Portal 配置 ============
# Portal 数据库 (独立数据库)
DATABASE_URL=sqlite:////opt/wg-manager/data/portal.db

# Portal 服务配置
PORTAL_HOST=0.0.0.0
PORTAL_PORT=8080

# Portal API 密钥 (供 Admin 调用 Portal API)
# 注意：此密钥需要在 Admin 后台的"Portal站点管理"中注册
PORTAL_API_KEY=your-portal-api-key-here

# Admin API 密钥 (Portal 调用 Admin API 时使用)
ADMIN_API_KEY=your-admin-api-key-here

# ============ Admin 配置 ============
# Admin 服务配置
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8081

# Portal 服务地址 (默认 Portal，用于向后兼容)
# 注意：多 Portal 场景请在后台"Portal站点管理"中添加
PORTAL_URL=http://127.0.0.1:8080
PORTAL_API_KEY=your-portal-api-key-here

# Admin API 密钥 (供 Portal 调用)
ADMIN_API_KEY=your-admin-api-key-here

# ============ Agent 配置 ============
# Agent 服务配置
AGENT_HOST=127.0.0.1
AGENT_PORT=8082
DEFAULT_AGENT_URL=http://127.0.0.1:8082
# Agent API密钥 (Admin调用Agent时使用的密钥，为空时使用ENCRYPTION_KEY)
AGENT_API_KEY=

# ============ 多 Portal 部署说明 ============
# Admin 可以管理多个 Portal 站点：
# 1. 每个 Portal 部署时生成唯一的 PORTAL_API_KEY
# 2. 在 Admin 后台"Portal站点管理"中添加每个 Portal：
#    - 名称：如"北京Portal"、"上海Portal"
#    - URL：Portal 的访问地址
#    - API 密钥：Portal 的 PORTAL_API_KEY
# 3. Admin 会根据 API 密钥识别请求来自哪个 Portal
