# 环境变量配置

# JWT密钥 (生产环境请修改，Portal 和 Admin 应使用相同密钥以便 JWT 验证)
SECRET_KEY=change-this-secret-key-in-production

# 数据加密密钥 (32字节，仅 Admin 使用)
ENCRYPTION_KEY=change-this-encryption-key-32bytes!!

# 超级管理员初始密码 (仅 Admin 使用)
SUPER_ADMIN_PASSWORD=admin123

# ============ Portal 配置 ============
# Portal 数据库 (独立数据库)
DATABASE_URL=sqlite:////opt/wg-manager/data/portal.db

# Portal 服务配置
PORTAL_HOST=0.0.0.0
PORTAL_PORT=8080

# Admin 服务地址 (Portal 调用 Admin API 时使用)
ADMIN_URL=http://127.0.0.1:8081
# 调用 Admin API 的密钥 (需与 Admin 的 ADMIN_API_KEY 一致)
ADMIN_API_KEY=

# Portal API 密钥 (供 Admin 调用 Portal API)
PORTAL_API_KEY=your-portal-api-key-here

# ============ Admin 配置 ============
# Admin 数据库 (独立数据库)
# 注意：Admin 使用 ENCRYPTION_KEY 进行数据加密
# 如需单独配置，可在 Admin 的 .env 中设置

# Admin 服务配置
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8081

# Portal 服务地址 (Admin 调用 Portal API 时使用)
PORTAL_URL=http://127.0.0.1:8080
# 调用 Portal API 的密钥 (需与 Portal 的 PORTAL_API_KEY 一致)
PORTAL_API_KEY=

# Admin API 密钥 (供 Portal 调用 Admin API)
ADMIN_API_KEY=your-admin-api-key-here

# ============ Agent 配置 ============
# Agent 服务配置
AGENT_HOST=127.0.0.1
AGENT_PORT=8082
DEFAULT_AGENT_URL=http://127.0.0.1:8082
# Agent API密钥 (Admin调用Agent时使用的密钥，为空时使用ENCRYPTION_KEY)
AGENT_API_KEY=
