# 环境变量配置

# JWT密钥 (生产环境请修改)
SECRET_KEY=change-this-secret-key-in-production

# 数据加密密钥 (32字节)
ENCRYPTION_KEY=change-this-encryption-key-32bytes!!

# 超级管理员初始密码
SUPER_ADMIN_PASSWORD=admin123

# 数据库路径
DATABASE_URL=sqlite:////opt/wg-manager/data/wg.db

# 服务端口
PORTAL_PORT=8080
ADMIN_PORT=8081
AGENT_PORT=8082

# Admin管理后台地址 (Portal独立部署时需要配置)
ADMIN_URL=http://127.0.0.1:8081
