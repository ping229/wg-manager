# WireGuard 管理系统配置文件

# ============ Portal 配置 ============

# JWT 密钥 (Portal 独立，无需与 Admin 相同)
SECRET_KEY=change-this-secret-key-in-production

# 数据加密密钥 (32字节)
ENCRYPTION_KEY=change-this-encryption-key-32bytes!!

# Portal 名称 (发送给 Admin 显示)
PORTAL_NAME=WireGuard Portal

# Portal API 密钥 (供 Admin 回调使用，随机生成)
PORTAL_API_KEY=your-portal-api-key-here

# Portal 外部访问地址 (发送给 Admin，用于回调)
# 如果不设置，将使用 PORTAL_HOST:PORTAL_PORT
PORTAL_URL=http://your-portal-host:8080

# Portal 服务配置
PORTAL_HOST=0.0.0.0
PORTAL_PORT=8080

# 数据库路径
DATABASE_URL=sqlite:////opt/wg-manager/data/portal.db

# Admin 连接配置 (填写要连接的 Admin 信息)
ADMIN_URL=http://admin-host:8081
ADMIN_API_KEY=admin-api-key-from-admin-backend

# ============ Admin 配置 ============

# JWT 密钥 (Admin 独立)
# SECRET_KEY=change-this-secret-key-in-production

# 数据加密密钥 (32字节，用于加密存储的敏感数据)
# ENCRYPTION_KEY=change-this-encryption-key-32bytes!!

# 超级管理员初始密码
SUPER_ADMIN_PASSWORD=admin123

# Admin 服务配置
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8081

# Admin 外部访问地址 (用于通知 Portal)
# ADMIN_URL=http://your-admin-host:8081

# ============ Agent 配置 ============
AGENT_HOST=127.0.0.1
AGENT_PORT=8082
DEFAULT_AGENT_URL=http://127.0.0.1:8082
AGENT_API_KEY=

# ============ 部署说明 ============
#
# Portal 部署步骤:
# 1. 配置 .env 文件，设置 ADMIN_URL 和 ADMIN_API_KEY
# 2. 启动 Portal 服务
# 3. 访问 Portal 首页，点击"申请接入"
# 4. 等待 Admin 审核通过
#
# Admin 部署步骤:
# 1. 启动 Admin 服务
# 2. 访问 Admin 后台 (默认: admin / admin123)
# 3. 在"Portal接入管理"中审核 Portal 申请
# 4. 审核通过后 Portal 可正常使用
