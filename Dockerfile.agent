FROM python:3.10-slim

LABEL maintainer="WireGuard Manager Agent"
LABEL description="WireGuard Agent Service"

# 安装依赖
RUN apt-get update && apt-get install -y \
    wireguard-tools \
    iproute2 \
    iptables \
    nftables \
    ipset \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 复制依赖文件
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制后端代码
COPY backend/ ./backend/

# 创建必要的目录
RUN mkdir -p /app/data /app/logs

# 环境变量
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

EXPOSE 8082

# 启动 Agent 服务
CMD ["uvicorn", "backend.agent.main:app", "--host", "0.0.0.0", "--port", "8082"]
